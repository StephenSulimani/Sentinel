# Copy to ".env" in this directory (repo root, next to docker-compose.yml).
# Docker Compose loads this file into the `ai` container via `env_file` (optional).
# Interpolation `${GEMINI_API_KEY}` in compose also reads this `.env` — avoid wrapping
# secrets in quotes unless you intend quotes to be part of the value.

# --- Gemini (primary narrative / LaTeX generation) ---
# https://ai.google.dev/gemini-api/docs
GEMINI_API_KEY=
# Examples: gemini-2.0-flash, gemini-2.5-flash-preview-05-20
GEMINI_MODEL=gemini-2.0-flash

# Market history uses yfinance (no separate API key).

# --- SearXNG (headlines) ---
# In Docker Compose the default is http://searxng:8080 (service DNS on the compose network).
# If you run the Flask AI app on the host, use http://127.0.0.1:8080 (host-published port).
# From *inside* the `ai` container, do not use 127.0.0.1 to reach SearXNG — use `searxng:8080`.
# Optional extra bases (comma-separated), e.g. SEARXNG_FALLBACK_URLS=http://192.168.1.5:8080
# SEARXNG_URL=http://127.0.0.1:8080

# --- SEC EDGAR (required descriptive User-Agent) ---
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=YourCompany ProjectSentinel/1.0 (mailto:you@example.com)

# Suggested additional sources (not wired yet; good next integrations):
# - FRED (macro): https://fred.stlouisfed.org/docs/api/api_key.html
# - Polygon.io (alt market + fundamentals): https://polygon.io/
# - OpenFIGI / FactSet symbology for class-action / ADR mapping
# - SEC full-text search API for MD&A snippets (heavier compliance surface)
